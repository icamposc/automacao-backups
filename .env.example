# ============================================================
# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA versione o arquivo .env no git!
# ============================================================

# --- Google Service Account ---
# Caminho para o arquivo JSON da Service Account
GOOGLE_CREDENCIAIS_PATH=config/credenciais/service-account.json

# E-mail do administrador para delegação de domínio (Domain-Wide Delegation)
GOOGLE_ADMIN_EMAIL=admin@seudominio.com

# --- Google Vault ---
# ID do Matter "BkpE-mails" no Google Vault (string alfanumérica)
VAULT_MATTER_ID=seu-matter-id-aqui

# --- Google Drive (FALLBACK) ---
# Usado apenas se o envio para o NAS_SYNC_DIR falhar (ex: disco cheio, permissao).
# ID da pasta de destino no Shared Drive "MM - Tech - ITO - Backups"
DRIVE_PASTA_DESTINO_ID=id-da-pasta-no-shared-drive

# --- NAS Synology (DESTINO PRIMARIO) ---
# Pasta local onde o servidor disponibiliza os ZIPs finalizados para o NAS puxar.
# O NAS deve acessar essa pasta (SMB/NFS), copiar o conteudo, e ao final renomear
# o marker <arquivo>.zip.ready para <arquivo>.zip.uploaded sinalizando que pode
# ser apagado pelo servidor apos o periodo de retencao.
NAS_SYNC_DIR=/mnt/hdd/vault/sync_nas

# Dias que ZIPs sincronizados (.uploaded) ficam preservados antes de serem apagados.
NAS_SYNC_RETENCAO_DIAS=7

# Horas em 'aguardando_nas' antes do servidor finalizar o backup (fecha ticket,
# exclui conta se aplicavel). Tempo dado ao NAS para coletar o ZIP. Default: 6.
NAS_SYNC_HORAS_ESPERA=6

# --- Jira Service Management ---
# URL base da instância Jira (ex: https://suaempresa.atlassian.net)
JIRA_URL_BASE=https://suaempresa.atlassian.net

# E-mail da conta que fará as atualizações nos tickets
JIRA_EMAIL=automacao@suaempresa.com

# Token de API do Jira (gerado em: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=seu-token-aqui

# Segredo do webhook do Jira (para validar requisições recebidas)
JIRA_WEBHOOK_SEGREDO=segredo-do-webhook

# Cloud ID da instância Atlassian — necessário para a API de Formulários do Jira
# Obtenha em: GET https://[instancia].atlassian.net/_edge/tenant_info
# Se vazio, a submissão automática de formulários é pulada (apenas warning)
JIRA_CLOUD_ID=

# IDs de transição do workflow no projeto SPN
# Descubra com: GET /rest/api/3/issue/{ticket}/transitions
JIRA_TRANSICAO_EM_ANALISE=
JIRA_TRANSICAO_RESOLVIDO=

# --- Google Chat ---
# Webhook do chat principal — notificações operacionais (início, progresso, sucesso)
# (Crie em: Espaço do Chat → Apps e integrações → Adicionar webhooks)
GOOGLE_CHAT_WEBHOOK_URL=

# Webhook do chat de LOGS — erros técnicos, falhas e alertas de saúde do sistema
# Aponta para o grupo "LOG - Automação Backups". Se vazio, esses alertas
# usam o webhook principal acima como fallback.
GOOGLE_CHAT_WEBHOOK_URL_LOGS=

# --- Servidor ---
# Porta em que o servidor Flask vai escutar
SERVIDOR_PORTA=5000

# Host do servidor (0.0.0.0 para aceitar conexões externas)
SERVIDOR_HOST=0.0.0.0

# --- Limites de Processamento ---
# Intervalo entre verificações de status do export no Vault (em segundos)
POLLING_INTERVALO_SEGUNDOS=60

# Tempo máximo de espera para um export completar (em segundos) — 4 horas
TIMEOUT_MAXIMO_SEGUNDOS=14400

# Número máximo de exports simultâneos no Vault (limite Google: 20)
MAX_EXPORTS_SIMULTANEOS=18
