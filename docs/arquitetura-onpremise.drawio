        <mxCell id="cleanup" value="🧹 Limpeza&#xa;• Remove temp/ após upload&#xa;• Logs: 30 dias ou 10 GB&#xa;• Trunca .log ativo (handler)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="proc-bg">
