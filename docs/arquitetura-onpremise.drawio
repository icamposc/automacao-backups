        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- SERVIDOR ON-PREMISE                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <mxCell id="server-bg" value="🖥️  Servidor On-Premise  (Ubuntu 22.04 LTS)" style="swimlane;startSize=35;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=15;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="50" width="2250" height="1670" as="geometry" />
        </mxCell>

        <!-- ── Firewall (entrada, acima do Flask) ── -->
        <mxCell id="firewall" value="🔒 Firewall&#xa;Porta 5000&#xa;→ Jira Cloud" style="shape=mxgraph.cisco.firewalls.firewall;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#6c0000;fontStyle=1;fontSize=12;" vertex="1" parent="server-bg">
          <mxGeometry x="315" y="65" width="120" height="90" as="geometry" />
        </mxCell>

        <!-- ── Linha 1: Flask | Redis | Celery ── -->
        <mxCell id="flask-bg" value="Gunicorn + Flask  (porta 5000)" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="210" width="700" height="460" as="geometry" />
        </mxCell>

        <mxCell id="webhook-handler" value="📥 Webhook Handler&#xa;&#xa;• Valida HMAC-SHA256&#xa;• Extrai e-mail via regex&#xa;• Verifica duplicata no DB&#xa;• Enfileira: .delay()" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="flask-bg">
          <mxGeometry x="20" y="50" width="320" height="390" as="geometry" />
        </mxCell>

        <mxCell id="dashboard" value="📊 Dashboard + Health&#xa;&#xa;GET /dashboard&#xa;  → lê SQLite (paginado)&#xa;&#xa;GET /health&#xa;  → banco, Redis, ativos&#xa;&#xa;GET /saude (compat.)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="flask-bg">
          <mxGeometry x="360" y="50" width="320" height="390" as="geometry" />
        </mxCell>

        <mxCell id="redis" value="🔴 Redis  (localhost:6379)&#xa;&#xa;Broker + Backend do Celery&#xa;Fila de tarefas de backup" style="rounded=1;fillColor=#ffcccc;strokeColor=#cc0000;fontColor=#660000;fontStyle=1;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="server-bg">
          <mxGeometry x="790" y="360" width="400" height="160" as="geometry" />
        </mxCell>

        <mxCell id="celery-bg" value="⚙️  Celery Worker  (--concurrency=1)" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="1260" y="210" width="970" height="460" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" value="🧭 Orquestrador&#xa;&#xa;Executa 8 etapas em sequência:&#xa;  1. Notifica Jira (início)&#xa;  2. Cria exports no Vault&#xa;  3. Monitora exports (paralelo)&#xa;  4. Baixa arquivos do Cloud Storage&#xa;  5. Compacta ZIP + calcula SHA256&#xa;  6. Faz upload para o Drive&#xa;  7. Atualiza Jira (fim)&#xa;  8. Verifica backup e exclui conta" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="celery-bg">
          <mxGeometry x="20" y="50" width="930" height="390" as="geometry" />
        </mxCell>

        <!-- ── Linha 2: Serviços de Integração ── -->
        <mxCell id="services-bg" value="Serviços — Integrações" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="740" width="2210" height="310" as="geometry" />
        </mxCell>

        <mxCell id="svc-vault" value="🗄️ Vault Service&#xa;&#xa;• Cria / reutiliza exports&#xa;• Monitoramento paralelo&#xa;• Download Cloud Storage&#xa;• Backoff exp.:&#xa;  30s→60s→120s→300s" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="20" y="45" width="340" height="245" as="geometry" />
        </mxCell>

        <mxCell id="svc-drive" value="☁️ Drive Upload&#xa;&#xa;• Upload chunked resumível&#xa;• Via AuthorizedSession&#xa;• SHA256 nos metadados&#xa;  (description + appProperties)&#xa;• Backoff exponencial" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="380" y="45" width="340" height="245" as="geometry" />
        </mxCell>

        <mxCell id="svc-jira" value="🎫 Jira Service&#xa;&#xa;• Comentários e Transições&#xa;• Campos obrigatórios&#xa;  (resolução, tipo, custo)&#xa;• Submissão de formulários&#xa;• API Token + Cloud ID" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="740" y="45" width="340" height="245" as="geometry" />
        </mxCell>

        <mxCell id="svc-conta" value="👤 Conta Exclusão&#xa;&#xa;• Verifica backup no Drive&#xa;• Deleta conta Workspace&#xa;• Admin resolvido por&#xa;  domínio (multi-domain)&#xa;• Operação irreversível" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="1100" y="45" width="340" height="245" as="geometry" />
        </mxCell>

        <mxCell id="svc-chat" value="💬 Google Chat&#xa;&#xa;• Notifica início e sucesso&#xa;• Avisa Vault reutilizado&#xa;• 5 alertas de falha:&#xa;  ⏱ Vault timeout&#xa;  📥 Download  📤 Upload&#xa;  🗑 Conta    🎫 Jira" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="1460" y="45" width="340" height="245" as="geometry" />
        </mxCell>

        <mxCell id="svc-auth" value="🔑 Google Auth&#xa;&#xa;Service Account JSON&#xa;Domain-Wide Delegation&#xa;&#xa;Múltiplos domínios:&#xa;GOOGLE_DOMINIOS_ADMIN&#xa;{ domínio → admin e-mail }" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4400;fontStyle=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="services-bg">
          <mxGeometry x="1840" y="45" width="350" height="245" as="geometry" />
        </mxCell>

        <!-- ── Linha 3: Processamento | Armazenamento ── -->
        <mxCell id="proc-bg" value="Processamento Local" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="1130" width="1080" height="280" as="geometry" />
        </mxCell>

        <mxCell id="compress" value="🗜️ Compactação&#xa;&#xa;• Formato ZIP_DEFLATED&#xa;• Calcula SHA256&#xa;  em blocos de 8 MB&#xa;• Verifica espaço em disco" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="proc-bg">
          <mxGeometry x="20" y="50" width="510" height="210" as="geometry" />
        </mxCell>

        <mxCell id="cleanup" value="🧹 Limpeza&#xa;&#xa;• Remove temp/ após upload&#xa;• Logs: 30 dias ou 10 GB&#xa;• Trunca .log ativo&#xa;  via handler" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="proc-bg">
          <mxGeometry x="550" y="50" width="510" height="210" as="geometry" />
        </mxCell>

        <mxCell id="storage-bg" value="💾 Armazenamento Local" style="swimlane;startSize=30;fillColor=#fff8e1;strokeColor=#f57f17;fontColor=#e65100;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="1150" y="1130" width="1080" height="280" as="geometry" />
        </mxCell>

        <mxCell id="temp" value="📁 temp/&#xa;&#xa;Arquivos durante&#xa;o processo de backup" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=11;verticalAlign=middle;" vertex="1" parent="storage-bg">
          <mxGeometry x="20" y="45" width="240" height="210" as="geometry" />
        </mxCell>

        <mxCell id="logs" value="📋 logs/&#xa;&#xa;automacao_backups.log&#xa;Retenção: 30 dias / 10 GB" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=11;verticalAlign=middle;" vertex="1" parent="storage-bg">
          <mxGeometry x="280" y="45" width="240" height="210" as="geometry" />
        </mxCell>

        <mxCell id="cred" value="🔐 credenciais/&#xa;&#xa;service-account.json&#xa;ca-bundle.crt" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=11;verticalAlign=middle;" vertex="1" parent="storage-bg">
          <mxGeometry x="540" y="45" width="240" height="210" as="geometry" />
        </mxCell>

        <mxCell id="sqlite" value="🗃️ SQLite&#xa;&#xa;dados/backups.db&#xa;Histórico + estado&#xa;das etapas&#xa;(WAL mode)" style="shape=mxgraph.flowchart.stored_data;fillColor=#e1f0ff;strokeColor=#1565c0;fontColor=#0d47a1;fontStyle=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="storage-bg">
          <mxGeometry x="800" y="45" width="260" height="210" as="geometry" />
        </mxCell>

        <!-- ── Linha 4: systemd ── -->
        <mxCell id="systemd" value="🔁 systemd — Supervisão de Processos&#xa;&#xa;• automacao-backups.service    →    Gunicorn + Flask (porta 5000)&#xa;• automacao-celery.service      →    Celery Worker (--concurrency=1)&#xa;&#xa;Restart automático em caso de falha" style="rounded=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=12;verticalAlign=middle;align=left;spacingLeft=20;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="1490" width="2210" height="120" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- GOOGLE CLOUD APIs                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <mxCell id="google-bg" value="☁️  Google Cloud APIs" style="swimlane;startSize=35;fillColor=#fce4ec;strokeColor=#880e4f;fontColor=#880e4f;fontStyle=1;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="2780" y="70" width="380" height="1100" as="geometry" />
        </mxCell>

        <mxCell id="g-vault" value="🗄️ Google Vault API&#xa;&#xa;Cria e monitora exports&#xa;de E-mail e Drive&#xa;Matter: Automacao-Backups" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="google-bg">
          <mxGeometry x="20" y="55" width="340" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g-gcs" value="📦 Cloud Storage&#xa;&#xa;Armazena arquivos exportados&#xa;pelo Vault&#xa;(buckets temporários)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="google-bg">
          <mxGeometry x="20" y="225" width="340" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g-drive" value="💾 Google Drive API&#xa;&#xa;Drive Compartilhado&#xa;Backup ZIP + SHA256&#xa;(appProperties + description)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="google-bg">
          <mxGeometry x="20" y="395" width="340" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g-admin" value="👤 Admin SDK Directory v1&#xa;&#xa;Exclusão da conta Workspace&#xa;Admin resolvido por domínio&#xa;(Domain-Wide Delegation)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="google-bg">
          <mxGeometry x="20" y="565" width="340" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g-chat" value="💬 Google Chat Webhook&#xa;&#xa;Cards v2 com 5 tipos de alerta:&#xa;Início, Sucesso, Vault timeout,&#xa;Download, Upload, Conta, Jira" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;verticalAlign=top;align=left;spacingLeft=8;spacingTop=8;" vertex="1" parent="google-bg">
          <mxGeometry x="20" y="735" width="340" height="140" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONEXÕES                                                        -->
        <!--                                                                 -->
        <!-- Categorias de cor:                                              -->
        <!--  🔵 Azul  (#1565c0) — Jira / entrada HTTP                     -->
        <!--  🟢 Verde (#2e7d32) — resposta OK do servidor                  -->
        <!--  🔴 Vermelho (#cc0000) — fila Celery/Redis  (strokeWidth=3)   -->
        <!--  🔷 Azul claro (#1565c0 dashed) — leitura/gravação SQLite     -->
        <!--  ⬛ Cinza (#444444) — Orquestrador → Serviços internos        -->
        <!--  🟣 Rosa (#880e4f) — Serviços → Google Cloud APIs             -->
        <!--  🟠 Laranja (#e65100) — fluxo de arquivos locais              -->
        <!--  🟡 Âmbar (#d79b00 dashed) — carregamento de credenciais      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <!-- ── 🔵 Jira Automation → Firewall ── -->
        <mxCell id="conn-jira-fw" value="POST /webhook/backup-desligado&#xa;{ descricao, ticket_id }" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#1565c0;strokeWidth=3;fontColor=#1565c0;fontStyle=1;fontSize=12;endArrow=block;endFill=1;" edge="1" source="jira-automation" target="firewall" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🟢 Firewall → Webhook Handler ── -->
        <mxCell id="conn-fw-wh" value="HTTP 200 imediato" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#2e7d32;strokeWidth=3;fontColor=#2e7d32;fontStyle=1;fontSize=12;endArrow=block;endFill=1;" edge="1" source="firewall" target="webhook-handler" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🔴 Webhook Handler → Redis  (enfileiramento assíncrono) ── -->
        <mxCell id="conn-wh-redis" value="executar_backup.delay(email, ticket_id)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#cc0000;strokeWidth=4;fontColor=#cc0000;fontStyle=1;fontSize=12;endArrow=block;endFill=1;" edge="1" source="webhook-handler" target="redis" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🔴 Redis → Celery Worker  (consumo da tarefa) ── -->
        <mxCell id="conn-redis-celery" value="Consome tarefa  (task_acks_late=True)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#cc0000;strokeWidth=4;fontColor=#cc0000;fontStyle=1;fontSize=12;endArrow=block;endFill=1;" edge="1" source="redis" target="orchestrator" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🔷 Webhook Handler → SQLite  (verifica duplicata) ── -->
        <mxCell id="conn-wh-sqlite" value="Verifica duplicata" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#1565c0;strokeWidth=2;fontColor=#1565c0;fontStyle=2;fontSize=12;endArrow=open;endFill=0;dashed=1;dashPattern=10 5;" edge="1" source="webhook-handler" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🔷 Dashboard → SQLite  (lê histórico paginado) ── -->
        <mxCell id="conn-dash-sqlite" value="Lê histórico paginado" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#1565c0;strokeWidth=2;fontColor=#1565c0;fontStyle=2;fontSize=12;endArrow=open;endFill=0;dashed=1;dashPattern=10 5;" edge="1" source="dashboard" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── 🔷 Orchestrator → SQLite  (persiste estado) ── -->
        <mxCell id="conn-orc-sqlite" value="Persiste estado das 8 etapas" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#1565c0;strokeWidth=2;fontColor=#1565c0;fontStyle=1;fontSize=12;endArrow=block;endFill=1;dashed=1;dashPattern=10 5;" edge="1" source="orchestrator" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

