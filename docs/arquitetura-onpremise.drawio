        <!-- children de celery-bg; coords relativas a celery-bg -->
        <mxCell id="orchestrator" value="🧭 Orquestrador&#xa;&#xa;Executa 8 etapas em sequência:&#xa;  1. Notifica Jira (início)&#xa;  2. Cria exports no Vault&#xa;  3. Monitora exports (paralelo)&#xa;  4. Baixa arquivos do Cloud Storage&#xa;  5. Compacta ZIP + calcula SHA256&#xa;  6. Faz upload para o Drive&#xa;  7. Atualiza Jira (fim)&#xa;  8. Verifica backup e exclui conta"
          style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;"
          vertex="1" parent="celery-bg">
          <mxGeometry x="20" y="50" width="955" height="425" as="geometry" />
        </mxCell>

