        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONEXÕES                                                -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <!-- Jira Automation → Firewall -->
        <mxCell id="conn-jira-fw" value="POST /webhook/backup-desligado&#xa;HTTPS :5000  { descricao, ticket_id }" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;fontColor=#1565c0;fontStyle=1;fontSize=10;" edge="1" source="jira-automation" target="firewall" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Firewall → Webhook Handler -->
