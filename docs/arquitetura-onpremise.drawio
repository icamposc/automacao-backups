        <!-- ═══════════════════════════════════════════════════════════════════
             CONEXÕES
             REGRA: parent = ancestral comum mais próximo de source e target
             - source e target ambos em server-bg  → parent="server-bg"
             - source ou target em containers diferentes (jira/google) → parent="1"
        ═══════════════════════════════════════════════════════════════════ -->

        <!-- ── Jira → Firewall  (jira-bg ↔ server-bg → parent=1) ── -->
        <mxCell id="conn-jira-fw" value="POST /webhook/backup-desligado&#xa;HTTPS :5000"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;strokeWidth=3;fontColor=#1565c0;fontStyle=1;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;labelBorderColor=none;"
          edge="1" source="jira-automation" target="firewall" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Firewall → Webhook  (ambos em server-bg → parent=server-bg) ── -->
        <mxCell id="conn-fw-wh" value="HTTP 200 imediato"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2e7d32;strokeWidth=3;fontColor=#2e7d32;fontStyle=1;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;labelBorderColor=none;"
          edge="1" source="firewall" target="webhook-handler" parent="server-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Webhook → Redis  (webhook em flask-bg, redis direto em server-bg → LCA=server-bg) ── -->
        <mxCell id="conn-wh-redis" value="executar_backup.delay(email, ticket_id)"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;strokeWidth=4;fontColor=#cc0000;fontStyle=1;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;labelBorderColor=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="webhook-handler" target="redis" parent="server-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Redis → Orchestrator  (redis direto, orchestrator em celery-bg → LCA=server-bg) ── -->
        <mxCell id="conn-redis-celery" value="Consome tarefa (task_acks_late=True)"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;strokeWidth=4;fontColor=#cc0000;fontStyle=1;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;labelBorderColor=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="redis" target="orchestrator" parent="server-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

