  <diagram name="Arquitetura On-Premise v2.0" id="arquitetura-onpremise-v2">
    <mxGraphModel dx="1800" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- JIRA CLOUD                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="jira-bg" value="☁️  Jira Cloud" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#1565c0;fontColor=#0d47a1;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="300" height="280" as="geometry" />
        </mxCell>

        <mxCell id="jira-automation" value="⚡ Automation for Jira&#xa;• Cria chamado SPN filho&#xa;  (Backup desligamento)&#xa;• Dispara webhook POST&#xa;  ao fechar ACCESS pai" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="jira-bg">
          <mxGeometry x="20" y="50" width="125" height="200" as="geometry" />
        </mxCell>

        <mxCell id="jira-api" value="🔧 Jira REST API v3&#xa;• Comentários&#xa;• Transições de status&#xa;• Formulários ProForma&#xa;  (X-ExperimentalApi)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="jira-bg">
          <mxGeometry x="155" y="50" width="125" height="200" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SERVIDOR ON-PREMISE                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="server-bg" value="🖥️  Servidor On-Premise (Ubuntu 22.04 LTS)" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=14;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="60" width="1200" height="1140" as="geometry" />
        </mxCell>

        <!-- Firewall -->
        <mxCell id="firewall" value="🔒 Firewall&#xa;Porta 5000&#xa;→ Jira Cloud" style="shape=mxgraph.cisco.firewalls.firewall;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#6c0000;fontStyle=1;fontSize=11;" vertex="1" parent="server-bg">
          <mxGeometry x="560" y="50" width="80" height="70" as="geometry" />
        </mxCell>

        <!-- ─── Gunicorn + Flask ─────────────────────────────────── -->
        <mxCell id="flask-bg" value="Gunicorn + Flask  (porta 5000)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="160" width="450" height="260" as="geometry" />
        </mxCell>

        <mxCell id="webhook-handler" value="📥 Webhook Handler&#xa;• Valida HMAC-SHA256&#xa;• Extrai e-mail via regex&#xa;• Verifica duplicata no DB&#xa;• Enfileira: .delay()" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="flask-bg">
          <mxGeometry x="15" y="40" width="200" height="195" as="geometry" />
        </mxCell>

        <mxCell id="dashboard" value="📊 Dashboard + Health&#xa;GET /dashboard&#xa;  → lê SQLite (paginado)&#xa;GET /health&#xa;  → banco, Redis, ativos&#xa;GET /saude (compat.)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="flask-bg">
          <mxGeometry x="230" y="40" width="200" height="195" as="geometry" />
        </mxCell>

        <!-- ─── Redis ─────────────────────────────────────────────── -->
        <mxCell id="redis" value="🔴 Redis  (localhost:6379)&#xa;Broker + Backend do Celery&#xa;Fila de tarefas de backup" style="rounded=1;fillColor=#ffcccc;strokeColor=#cc0000;fontColor=#660000;fontStyle=1;fontSize=11;" vertex="1" parent="server-bg">
          <mxGeometry x="530" y="210" width="260" height="100" as="geometry" />
        </mxCell>

        <!-- ─── Celery Worker ──────────────────────────────────────── -->
        <mxCell id="celery-bg" value="⚙️  Celery Worker  (--concurrency=1)" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="850" y="160" width="330" height="280" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" value="🧭 Orquestrador&#xa;8 etapas em sequência:&#xa;1. Notifica Jira (início)&#xa;2. Cria exports Vault&#xa;3. Monitora (paralelo)&#xa;4. Baixa arquivos&#xa;5. Compacta ZIP + SHA256&#xa;6. Upload Drive&#xa;7. Atualiza Jira (fim)&#xa;8. Verifica + Exclui conta" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=10;" vertex="1" parent="celery-bg">
          <mxGeometry x="15" y="40" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- ─── Serviços ────────────────────────────────────────────── -->
        <mxCell id="services-bg" value="Serviços — Integrações" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="490" width="1160" height="200" as="geometry" />
        </mxCell>

        <mxCell id="svc-vault" value="🗄️ Vault Service&#xa;• Cria / reutiliza exports&#xa;• Monitoramento paralelo&#xa;• Download Cloud Storage&#xa;• Backoff exponencial&#xa;  30s → 60s → 120s → 300s" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="15" y="40" width="175" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc-drive" value="☁️ Drive Upload&#xa;• Upload chunked resumível&#xa;• Via AuthorizedSession&#xa;• SHA256 nos metadados&#xa;• description + appProperties&#xa;• Backoff exponencial" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="205" y="40" width="175" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc-jira" value="🎫 Jira Service&#xa;• Comentários + Transições&#xa;• Campos obrigatórios&#xa;  (resolução, tipo, custo)&#xa;• Submissão de formulários&#xa;• API Token + Cloud ID" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="395" y="40" width="175" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc-conta" value="👤 Conta Exclusão&#xa;• Verifica backup no Drive&#xa;• Deleta conta Workspace&#xa;• Admin resolvido por&#xa;  domínio (multi-domain)&#xa;• Operação irreversível" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="585" y="40" width="175" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc-chat" value="💬 Google Chat&#xa;• Início / Sucesso&#xa;• Vault reutilizado&#xa;• 5 alertas de falha:&#xa;  ⏱ Vault timeout&#xa;  📥 Download&#xa;  📤 Upload&#xa;  🗑 Exclusão conta&#xa;  🎫 Jira" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="775" y="40" width="175" height="140" as="geometry" />
        </mxCell>

        <mxCell id="svc-auth" value="🔑 Google Auth&#xa;Service Account JSON&#xa;Domain-Wide Delegation&#xa;&#xa;Múltiplos domínios:&#xa;GOOGLE_DOMINIOS_ADMIN&#xa;domínio → admin e-mail" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4400;fontStyle=1;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="965" y="40" width="180" height="140" as="geometry" />
        </mxCell>

        <!-- ─── Processamento ──────────────────────────────────────── -->
        <mxCell id="proc-bg" value="Processamento Local" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="740" width="580" height="160" as="geometry" />
        </mxCell>

        <mxCell id="compress" value="🗜️ Compactação&#xa;• ZIP_DEFLATED&#xa;• Calcula SHA256 (blocos 8MB)&#xa;• Verifica espaço em disco" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="proc-bg">
          <mxGeometry x="15" y="40" width="260" height="100" as="geometry" />
