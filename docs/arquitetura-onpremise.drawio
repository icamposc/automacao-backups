        <!-- ─── Systemd (processos supervisionados) ──────────────── -->
        <mxCell id="systemd" value="🔁 systemd&#xa;• automacao-backups.service&#xa;  (Gunicorn Flask)&#xa;• automacao-celery.service&#xa;  (Celery Worker)&#xa;Restart automático" style="rounded=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=10;" vertex="1" parent="server-bg">
