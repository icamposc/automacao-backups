          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Webhook Handler → Redis (enfileira) -->
        <mxCell id="conn-wh-redis" value="executar_backup.delay(&#xa;  email, ticket_id)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;fontColor=#cc0000;fontStyle=1;fontSize=10;" edge="1" source="webhook-handler" target="redis" parent="1">
          <mxGeometry relative="1" as="geometry" />
