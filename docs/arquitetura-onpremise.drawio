        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SERVIDOR ON-PREMISE  (coluna central)                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="server-bg" value="🖥️  Servidor On-Premise (Ubuntu 22.04 LTS)" style="swimlane;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=14;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="50" width="1580" height="1390" as="geometry" />
        </mxCell>

        <!-- ── Linha 0: Firewall (ponto de entrada, centralizado acima do Flask) ── -->
        <mxCell id="firewall" value="🔒 Firewall&#xa;Porta 5000&#xa;→ Jira Cloud" style="shape=mxgraph.cisco.firewalls.firewall;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#6c0000;fontStyle=1;fontSize=11;" vertex="1" parent="server-bg">
          <mxGeometry x="240" y="50" width="100" height="75" as="geometry" />
        </mxCell>

        <!-- ── Linha 1: Flask | Redis | Celery ── -->
        <mxCell id="flask-bg" value="Gunicorn + Flask  (porta 5000)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="175" width="540" height="295" as="geometry" />
        </mxCell>

        <mxCell id="webhook-handler" value="📥 Webhook Handler&#xa;• Valida HMAC-SHA256&#xa;• Extrai e-mail via regex&#xa;• Verifica duplicata no DB&#xa;• Enfileira: .delay()" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="flask-bg">
          <mxGeometry x="20" y="45" width="240" height="230" as="geometry" />
        </mxCell>

        <mxCell id="dashboard" value="📊 Dashboard + Health&#xa;GET /dashboard&#xa;  → lê SQLite (paginado)&#xa;GET /health&#xa;  → banco, Redis, ativos&#xa;GET /saude (compat.)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#00307a;fontSize=11;" vertex="1" parent="flask-bg">
          <mxGeometry x="280" y="45" width="240" height="230" as="geometry" />
        </mxCell>

        <mxCell id="redis" value="🔴 Redis  (localhost:6379)&#xa;&#xa;Broker + Backend do Celery&#xa;Fila de tarefas de backup" style="rounded=1;fillColor=#ffcccc;strokeColor=#cc0000;fontColor=#660000;fontStyle=1;fontSize=12;" vertex="1" parent="server-bg">
          <mxGeometry x="610" y="245" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="celery-bg" value="⚙️  Celery Worker  (--concurrency=1)" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="960" y="175" width="600" height="295" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" value="🧭 Orquestrador&#xa;8 etapas em sequência:&#xa;1. Notifica Jira (início)&#xa;2. Cria exports Vault&#xa;3. Monitora (paralelo)&#xa;4. Baixa arquivos&#xa;5. Compacta ZIP + SHA256&#xa;6. Upload Drive&#xa;7. Atualiza Jira (fim)&#xa;8. Verifica + Exclui conta" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=11;" vertex="1" parent="celery-bg">
          <mxGeometry x="20" y="45" width="560" height="230" as="geometry" />
        </mxCell>

        <!-- ── Linha 2: Serviços de Integração ── -->
        <mxCell id="services-bg" value="Serviços — Integrações" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="530" width="1540" height="230" as="geometry" />
        </mxCell>

        <mxCell id="svc-vault" value="🗄️ Vault Service&#xa;• Cria / reutiliza exports&#xa;• Monitoramento paralelo&#xa;• Download Cloud Storage&#xa;• Backoff exponencial&#xa;  30s→60s→120s→300s" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="15" y="40" width="235" height="170" as="geometry" />
        </mxCell>

        <mxCell id="svc-drive" value="☁️ Drive Upload&#xa;• Upload chunked resumível&#xa;• Via AuthorizedSession&#xa;• SHA256 nos metadados&#xa;• description + appProperties&#xa;• Backoff exponencial" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="265" y="40" width="235" height="170" as="geometry" />
        </mxCell>

        <mxCell id="svc-jira" value="🎫 Jira Service&#xa;• Comentários + Transições&#xa;• Campos obrigatórios&#xa;  (resolução, tipo, custo)&#xa;• Submissão de formulários&#xa;• API Token + Cloud ID" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="515" y="40" width="235" height="170" as="geometry" />
        </mxCell>

        <mxCell id="svc-conta" value="👤 Conta Exclusão&#xa;• Verifica backup no Drive&#xa;• Deleta conta Workspace&#xa;• Admin resolvido por&#xa;  domínio (multi-domain)&#xa;• Operação irreversível" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="765" y="40" width="235" height="170" as="geometry" />
        </mxCell>

        <mxCell id="svc-chat" value="💬 Google Chat&#xa;• Início / Sucesso&#xa;• Vault reutilizado&#xa;• 5 alertas de falha:&#xa;  ⏱ Vault timeout&#xa;  📥 Download  📤 Upload&#xa;  🗑 Conta  🎫 Jira" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="1015" y="40" width="235" height="170" as="geometry" />
        </mxCell>

        <mxCell id="svc-auth" value="🔑 Google Auth&#xa;Service Account JSON&#xa;Domain-Wide Delegation&#xa;&#xa;Múltiplos domínios:&#xa;GOOGLE_DOMINIOS_ADMIN&#xa;domínio → admin e-mail" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4400;fontStyle=1;fontSize=10;" vertex="1" parent="services-bg">
          <mxGeometry x="1285" y="40" width="240" height="170" as="geometry" />
        </mxCell>

        <!-- ── Linha 3: Processamento | Armazenamento ── -->
        <mxCell id="proc-bg" value="Processamento Local" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a4700;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="820" width="750" height="195" as="geometry" />
        </mxCell>

        <mxCell id="compress" value="🗜️ Compactação&#xa;• ZIP_DEFLATED&#xa;• SHA256 em blocos de 8 MB&#xa;• Verifica espaço em disco" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="proc-bg">
          <mxGeometry x="15" y="45" width="350" height="130" as="geometry" />
        </mxCell>

        <mxCell id="cleanup" value="🧹 Limpeza&#xa;• Remove temp/ após upload&#xa;• Logs: 30 dias ou 10 GB&#xa;• Trunca .log ativo (handler)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="proc-bg">
          <mxGeometry x="385" y="45" width="350" height="130" as="geometry" />
        </mxCell>

        <mxCell id="storage-bg" value="💾 Armazenamento Local" style="swimlane;startSize=25;fillColor=#fff8e1;strokeColor=#f57f17;fontColor=#e65100;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="server-bg">
          <mxGeometry x="800" y="820" width="760" height="195" as="geometry" />
        </mxCell>

        <mxCell id="temp" value="📁 temp/&#xa;Arquivos&#xa;durante backup" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;" vertex="1" parent="storage-bg">
          <mxGeometry x="15" y="38" width="165" height="120" as="geometry" />
        </mxCell>

        <mxCell id="logs" value="📋 logs/&#xa;automacao_backups&#xa;.log — 30d / 10 GB" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;" vertex="1" parent="storage-bg">
          <mxGeometry x="195" y="38" width="165" height="120" as="geometry" />
        </mxCell>

        <mxCell id="cred" value="🔐 credenciais/&#xa;service-account&#xa;.json  ca-bundle.crt" style="shape=mxgraph.flowchart.stored_data;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=10;" vertex="1" parent="storage-bg">
          <mxGeometry x="375" y="38" width="165" height="120" as="geometry" />
        </mxCell>

        <mxCell id="sqlite" value="🗃️ SQLite&#xa;dados/backups.db&#xa;Histórico + estado&#xa;etapas (WAL mode)" style="shape=mxgraph.flowchart.stored_data;fillColor=#e1f0ff;strokeColor=#1565c0;fontColor=#0d47a1;fontStyle=1;fontSize=10;" vertex="1" parent="storage-bg">
          <mxGeometry x="555" y="38" width="185" height="120" as="geometry" />
        </mxCell>

        <!-- ── Linha 4: systemd ── -->
        <mxCell id="systemd" value="🔁 systemd  —  Supervisão de processos&#xa;• automacao-backups.service  (Gunicorn + Flask)          • automacao-celery.service  (Celery Worker)          Restart automático em caso de falha" style="rounded=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;fontSize=11;" vertex="1" parent="server-bg">
          <mxGeometry x="20" y="1080" width="1540" height="80" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- GOOGLE CLOUD APIs  (coluna direita)                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="google-bg" value="☁️  Google Cloud APIs" style="swimlane;startSize=30;fillColor=#fce4ec;strokeColor=#880e4f;fontColor=#880e4f;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="2050" y="60" width="320" height="920" as="geometry" />
        </mxCell>

        <mxCell id="g-vault" value="🗄️ Google Vault API&#xa;Cria e monitora&#xa;exports de E-mail e Drive&#xa;Matter: Automacao-Backups" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="google-bg">
          <mxGeometry x="25" y="55" width="270" height="110" as="geometry" />
        </mxCell>

        <mxCell id="g-gcs" value="📦 Cloud Storage&#xa;Armazena arquivos&#xa;exportados pelo Vault&#xa;(buckets temporários)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="google-bg">
          <mxGeometry x="25" y="200" width="270" height="110" as="geometry" />
        </mxCell>

        <mxCell id="g-drive" value="💾 Google Drive API&#xa;Drive Compartilhado&#xa;Backup ZIP + SHA256&#xa;(appProperties + description)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="google-bg">
          <mxGeometry x="25" y="345" width="270" height="110" as="geometry" />
        </mxCell>

        <mxCell id="g-admin" value="👤 Admin SDK Directory v1&#xa;Exclusão da conta&#xa;Admin resolvido por domínio&#xa;(Domain-Wide Delegation)" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="google-bg">
          <mxGeometry x="25" y="490" width="270" height="110" as="geometry" />
        </mxCell>

        <mxCell id="g-chat" value="💬 Google Chat Webhook&#xa;Cards v2 — 5 tipos de alerta&#xa;Início, Sucesso, Conta&#xa;+ falhas específicas" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="google-bg">
          <mxGeometry x="25" y="635" width="270" height="110" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONEXÕES                                               -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <!-- Jira Automation → Firewall -->
        <mxCell id="conn-jira-fw" value="POST /webhook/backup-desligado&#xa;HTTPS :5000  { descricao, ticket_id }" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;fontColor=#1565c0;fontStyle=1;fontSize=10;" edge="1" source="jira-automation" target="firewall" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Firewall → Webhook Handler -->
        <mxCell id="conn-fw-wh" value="HTTP 200 imediato" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2e7d32;fontColor=#2e7d32;fontSize=10;" edge="1" source="firewall" target="webhook-handler" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Webhook Handler → Redis (enfileira) -->
        <mxCell id="conn-wh-redis" value="executar_backup.delay(&#xa;  email, ticket_id)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;fontColor=#cc0000;fontStyle=1;fontSize=10;" edge="1" source="webhook-handler" target="redis" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Redis → Celery Worker (consome) -->
        <mxCell id="conn-redis-celery" value="Consome tarefa&#xa;(task_acks_late=True)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;fontColor=#cc0000;fontStyle=1;fontSize=10;" edge="1" source="redis" target="orchestrator" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Webhook Handler → SQLite (verifica duplicata) -->
        <mxCell id="conn-wh-sqlite" value="Verifica duplicata" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;fontColor=#1565c0;fontSize=10;dashed=1;" edge="1" source="webhook-handler" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Dashboard → SQLite (lê histórico) -->
        <mxCell id="conn-dash-sqlite" value="Lê histórico paginado&#xa;?pagina=&amp;por_pagina=" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;fontColor=#1565c0;fontSize=10;dashed=1;" edge="1" source="dashboard" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Orchestrator → SQLite (persiste estado) -->
        <mxCell id="conn-orc-sqlite" value="Persiste estado&#xa;das 8 etapas" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;fontColor=#1565c0;fontSize=10;dashed=1;" edge="1" source="orchestrator" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Orchestrator → Serviços -->
        <mxCell id="conn-orc-vault" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="orchestrator" target="svc-vault" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn-orc-drive" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="orchestrator" target="svc-drive" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn-orc-jira" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="orchestrator" target="svc-jira" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn-orc-conta" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="orchestrator" target="svc-conta" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn-orc-chat" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="orchestrator" target="svc-chat" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn-orc-comp" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;" edge="1" source="orchestrator" target="compress" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Credenciais → Auth -->
        <mxCell id="conn-cred-auth" value="Carrega JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;fontColor=#7a4400;fontSize=10;dashed=1;" edge="1" source="cred" target="svc-auth" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Serviços → Google Cloud APIs -->
        <mxCell id="conn-vault-gvault" value="Cria / monitora exports&#xa;(backoff exponencial)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#880e4f;fontColor=#880e4f;fontSize=10;" edge="1" source="svc-vault" target="g-vault" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="conn-vault-gcs" value="Download arquivos" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#880e4f;fontColor=#880e4f;fontSize=10;" edge="1" source="svc-vault" target="g-gcs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="conn-drive-gdrive" value="Upload ZIP + SHA256&#xa;(resumable, chunked)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#880e4f;fontColor=#880e4f;fontSize=10;" edge="1" source="svc-drive" target="g-drive" parent="1">
